{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Configure PicoRapidX2",
      "type": "shell",
      "command": "cmake",
      "args": [
        "-S", "..",
        "-B", ".",
        "-G", "Ninja"
      ],
      "options": {
        "cwd": "${workspaceFolder}/PicoRapidX2/build"
      },
      "problemMatcher": []
    },
    {
      "label": "Build PicoRapidX2",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build", ".",
        "--target", "PicoRapidX2"
      ],
      "options": {
        "cwd": "${workspaceFolder}/PicoRapidX2/build"
      },
      "dependsOn": "Configure PicoRapidX2",
      "problemMatcher": "$gcc",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    }
  ]
}
