{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build PicoRapidX2",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build", ".",
        "--target", "PicoRapidX2"
      ],
      "options": {
        "cwd": "${workspaceFolder}/build"
      },
      "problemMatcher": "$gcc",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    }
  ]
}
