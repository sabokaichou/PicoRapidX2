{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build PicoRapidX",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build", "${workspaceFolder}/build_ninja",
        "--target", "PicoRapidX"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": "$gcc",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    }
  ]
}
